{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@netcfs/ui": ["../../packages/ui/src/index.ts"],
      "@netcfs/ui/*": ["../../packages/ui/src/*"],
      "@netcfs/auth": ["../../packages/auth/src/index.ts"],
      "@netcfs/auth/*": ["../../packages/auth/src/*"],
      "@netcfs/db": ["../../packages/db/src/index.ts"],
      "@netcfs/db/*": ["../../packages/db/src/*"],
      "@netcfs/utils": ["../../packages/utils/src/index.ts"],
      "@netcfs/utils/*": ["../../packages/utils/src/*"]
    }
  }
}
